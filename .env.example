# ─────────────────────────────────────────────────────────────────
#  AegisMesh Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── LLM Backend ────────────────────────────────────────────────────
# Option A: OpenAI (cloud)
OPENAI_API_KEY=sk-REPLACE_ME
AEGIS_LLM_PROVIDER=openai
AEGIS_LLM_MODEL=gpt-4o-mini

# Option B: Ollama (local, privacy-first — recommended)
# AEGIS_LLM_PROVIDER=ollama
# AEGIS_LLM_MODEL=llama3
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# ── Registry ───────────────────────────────────────────────────────
AEGIS_REGISTRY_HOST=127.0.0.1
AEGIS_REGISTRY_PORT=8000
AEGIS_REGISTRY_DB=aegis_registry.db

# ── Evidence Graph ─────────────────────────────────────────────────
AEGIS_EVIDENCE_DB=aegis_evidence.db

# ── Observability ──────────────────────────────────────────────────
# Set to "none" to disable OTel export (useful in offline environments)
AEGIS_OTEL_ENDPOINT=none
# AEGIS_OTEL_ENDPOINT=http://127.0.0.1:4317

# ── Governor Thresholds ────────────────────────────────────────────
AEGIS_RAM_THRESHOLD_HIGH=85
AEGIS_RAM_THRESHOLD_MED=75
AEGIS_PARALLEL_WORKERS=8

# ── Security ───────────────────────────────────────────────────────
AEGIS_SANDBOX_ENABLED=true
